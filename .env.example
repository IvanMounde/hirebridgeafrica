# ══════════════════════════════════════════════════════════════════════════════
# HireBridge Africa — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_strong_random_key

# Your admin email — this account gets admin panel access
ADMIN_EMAILS=you@example.com

FLASK_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite locally (fine for development, not production).
# For production use a free PostgreSQL database:
#   Neon (recommended): https://neon.tech  — free forever, no expiry
#   Supabase:           https://supabase.com — free tier
#   Render Postgres:    free but expires after 90 days
#
# Paste the connection string from your provider:
# DATABASE_URL=postgresql://user:password@host/dbname

# ── Email (for password reset & booking notifications) ────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
# Use a Gmail App Password (not your real password):
# https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=your_16_char_app_password

# ── Resume storage (optional but recommended for production) ─────────────────
# Without this, uploaded CVs are saved to local disk and WILL BE LOST on every
# Render redeploy (Render's free tier has ephemeral disk).
# Sign up free at https://cloudinary.com (25GB free, no credit card needed),
# then copy the "API Environment variable" shown on your dashboard — it looks
# like: cloudinary://123456789012345:AbCdEfGhIjKlMnOpQrStUvWxYz@your_cloud_name
# CLOUDINARY_URL=

# ── Rate limiter ──────────────────────────────────────────────────────────────
# In-memory limiter is fine for a single worker (default).
# If you run multiple gunicorn workers, point this at a shared Redis instance:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── Scraper resource controls ─────────────────────────────────────────────────
# All optional — the defaults below are tuned for free-tier hosting.
# SCRAPER_MAX_WORKERS=4
# SCRAPER_GROUP_WORKERS=3
# SCRAPER_TIMEOUT=8
# SCRAPER_ATS_BATCH_SIZE=150
# SCRAPER_FETCH_BUDGET_SECONDS=45
# SCRAPER_INTERVAL_SECONDS=14400
# DISABLE_BACKGROUND_SCRAPER=false

# ── Optional job-scraper API keys (free tiers available) ──────────────────────
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# REED_API_KEY=
# FINDWORK_API_KEY=
# JSEARCH_API_KEY=
# JOOBLE_API_KEY=
# GOOGLE_ALERTS_RSS=
